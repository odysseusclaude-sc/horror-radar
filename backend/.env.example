# YouTube Data API v3 key (required for YouTube collection)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database URL (SQLite for local dev, swap to postgres:// for production)
DATABASE_URL=sqlite:///./horrorindie.db

# Collection intervals (hours)
STEAM_DISCOVERY_INTERVAL_HOURS=6
STEAM_REVIEWS_INTERVAL_HOURS=24
STEAM_CCU_INTERVAL_HOURS=6
STEAM_OWNERS_INTERVAL_HOURS=24
YOUTUBE_SCAN_INTERVAL_HOURS=24
YOUTUBE_STATS_INTERVAL_HOURS=24
OPS_INTERVAL_HOURS=24

# Fuzzy matching threshold (0-100) for YouTube title → game matching
FUZZY_MATCH_THRESHOLD=85

# Logging
LOG_LEVEL=INFO
