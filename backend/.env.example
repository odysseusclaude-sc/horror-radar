# YouTube Data API v3 key (required for YouTube collection)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database URL (SQLite for local dev, swap to postgres:// for production)
DATABASE_URL=sqlite:///./horrorindie.db

# Collection intervals (hours)
STEAM_DISCOVERY_INTERVAL_HOURS=6
STEAM_REVIEWS_INTERVAL_HOURS=24
STEAM_CCU_INTERVAL_HOURS=6
STEAM_OWNERS_INTERVAL_HOURS=24
YOUTUBE_SCAN_INTERVAL_HOURS=24
YOUTUBE_STATS_INTERVAL_HOURS=24
OPS_INTERVAL_HOURS=24

# Fuzzy matching threshold (0-100) for YouTube title → game matching
FUZZY_MATCH_THRESHOLD=85

# Logging
LOG_LEVEL=INFO

# Twitch API (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
TWITCH_INTERVAL_HOURS=6

# Reddit API (https://www.reddit.com/prefs/apps — create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=HorrorRadar/1.0
REDDIT_INTERVAL_HOURS=24
# Comma-separated subreddits to scan (default: horror-specific only)
# Add Steam,pcgaming,Games to expand coverage (more quota usage + noise)
REDDIT_SUBREDDITS=HorrorGaming,IndieGaming

# Steam extras (achievement stats + update frequency)
STEAM_EXTRAS_INTERVAL_HOURS=24

# Developer profiles (weekly computation from DB data)
DEV_PROFILE_INTERVAL_HOURS=168

# CORS — comma-separated additional allowed origins for the API
# Set to your Vercel frontend URL in production
CORS_ORIGINS=https://your-app.vercel.app

# Sentry error tracking (free tier: sentry.io — leave empty to disable)
SENTRY_DSN=

# OPS v5 weights (uncomment to override defaults)
# OPS_VELOCITY_WEIGHT=0.30
# OPS_DECAY_WEIGHT=0.20
# OPS_REVIEW_WEIGHT=0.13
# OPS_YOUTUBE_WEIGHT=0.13
# OPS_CCU_WEIGHT=0.10
# OPS_SENTIMENT_WEIGHT=0.08
# OPS_TWITCH_WEIGHT=0.06
# OPS_SCORE_MULTIPLIER=24.0
